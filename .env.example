# Backend Configuration
PORT=3000
NODE_ENV=development

# Security
# Comma-separated list of allowed origins for CORS (e.g., https://padhai.vercel.app)
ALLOWED_ORIGINS=http://localhost:3000

# API Keys
# Gemini is used strictly for OCR
GEMINI_API_KEY=your_gemini_api_key_here

# Groq is used for all text generation, segregation, and chat
GROQ_API_KEY=your_groq_api_key_here

# Frontend Configuration (If deploying frontend separately)
# VITE_API_URL=https://your-backend-url.onrender.com/api
